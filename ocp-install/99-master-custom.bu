variant: openshift
version: 4.20.0
metadata:
  name: 99-master-custom
  labels:
    machineconfiguration.openshift.io/role: master
openshift:
  kernel_arguments:
    - nomodeset
storage:
  files:
    - path: /etc/chrony.conf
      overwrite: true
      mode: 0644
      contents:
        inline: |
          server 192.168.30.2 iburst
          driftfile /var/lib/chrony/drift
          makestep 1.0 3
          rtcsync
          logdir /var/log/chrony
